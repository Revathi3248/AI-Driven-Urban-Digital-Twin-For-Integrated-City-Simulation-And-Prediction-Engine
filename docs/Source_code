 'police car', 'fire truck', 'barrier'],
 'Parking Analysis': ['car', 'truck', 'motorcycle', 'person', 'parking meter', 
 'parking sign', 'parking lot', 'street light'],
 'General Objects': self.available_objects[:25]
 }
 
 # Get relevant objects for the task
 relevant_objects = task_patterns.get(task, self.available_objects[:15])
 
 # Generate realistic detections based on task
