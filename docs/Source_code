 def analyze_image(self, image_file, task: str):
 """Analyze image with improved object detection"""
 try:
 # Read and process the image
 if hasattr(image_file, 'read'):
 image_bytes = image_file.read()
 image_file.seek(0)
 img_array = np.frombuffer(image_bytes, np.uint8)
 img = cv2.imdecode(img_array, cv2.IMREAD_COLOR)
 elif isinstance(image_file, str):
 if os.path.exists(image_file):
 img = cv2.imread(image_file)
 else:
 raise FileNotFoundError(f"Image not found: {image_file}")
 else:
 raise ValueError("Invalid image file type")
 
 if img is None:
 raise ValueError("Could not read image")
 
 # Create a hash for deterministic but varied results
 img_hash = hash(str(img.shape) + str(img.mean())) % 10000
 np.random.seed(img_hash)
 
 # Task-based detection patterns
 task_patterns = {
 'Traffic Analysis': ['car', 'truck', 'bus', 'motorcycle', 'bicycle', 'person', 
 'traffic light', 'stop sign', 'parking meter', 'bench'],
