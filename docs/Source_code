 """Rule-based fallback prediction"""
 hour = features.get('hour', 12)
 city = features.get('city', 'Unknown')
 day_type = features.get('day_type', 'weekday')
 
 # Simple rules
 risk_score = 0
 
 # Time-based risk
 if 7 <= hour <= 9 or 17 <= hour <= 19:
 risk_score += 2 # Rush hour
 
 if 22 <= hour <= 6:
 risk_score += 1 # Night driving
 
 # Day type
 if day_type == 'weekend':
 risk_score += 1
 
 # City-specific (simplified)
 city_risk = {
 'Mumbai': 2, 'Delhi': 2, 'Bangalore': 1,
 'Chennai': 1, 'Kolkata': 1, 'Hyderabad': 1
 }
 risk_score += city_risk.get(city, 0)
 
 # Determine risk level
 if risk_score >= 3:
 prediction = 1
 probability = 0.7 + (risk_score - 3) * 0.1
 else:
 prediction = 0
 probability = 0.3 + risk_score * 0.1
 
 return {
 'prediction': 'High Risk' if prediction == 1 else 'Low Risk',
 'probability': min(probability, 0.95),
 'risk_level': prediction
 }
 
