 'motorcycle': np.random.randint(0, 3),
 'bus': np.random.randint(0, 2)
 }
 total_objects = sum(object_counts.values())
 
 elif task == 'Environment Check':
 object_counts = {
 'tree': np.random.randint(5, 15),
 'bird': np.random.randint(2, 10),
 'dog': np.random.randint(0, 4),
 'cat': np.random.randint(0, 3),
 'person': np.random.randint(1, 7),
 'car': np.random.randint(0, 4),
 'building': np.random.randint(1, 5),
 'bench': np.random.randint(0, 2),
 'fountain': np.random.randint(0, 1),
 'statue': np.random.randint(0, 1)
 }
 total_objects = sum(object_counts.values())
 
 elif task == 'Emergency Detection':
 object_counts = {
 'person': np.random.randint(5, 15),
 'car': np.random.randint(3, 8),
 'truck': np.random.randint(1, 4),
 'fire hydrant': np.random.randint(0, 2),
 'ambulance': np.random.randint(0, 2),
