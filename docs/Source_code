 def calculate_aqi(self, data):
 """Calculate Air Quality Index from pollutants"""
 aqi_values = []
 for _, row in data.iterrows():
 # Simplified AQI calculation (US EPA standard)
 pm25 = row.get('pm2_5', 0)
 pm10 = row.get('pm10', 0)
 no2 = row.get('no2', 0)
 so2 = row.get('so2', 0)
 co = row.get('co', 0)
 o3 = row.get('o3', 0)
 
 # Calculate sub-indices
 sub_indices = [
 self._calculate_pm25_aqi(pm25),
 self._calculate_pm10_aqi(pm10),
 self._calculate_no2_aqi(no2),
 self._calculate_so2_aqi(so2),
 self._calculate_co_aqi(co),
 self._calculate_o3_aqi(o3)
 ]
 
 # Overall AQI is the maximum sub-index
 aqi = max(sub_indices)
 aqi_values.append(aqi)
 
 return aqi_values
 
 def _calculate_pm25_aqi(self, concentration):
 """Calculate PM2.5 AQI"""
 if concentration <= 12:
 return (concentration / 12) * 50
 elif concentration <= 35.4:
 return 50 + (concentration - 12) / (35.4 - 12) * 50
 elif concentration <= 55.4:
 return 100 + (concentration - 35.4) / (55.4 - 35.4) * 50
 elif concentration <= 150.4:
 return 150 + (concentration - 55.4) / (150.4 - 55.4) * 50
 elif concentration <= 250.4:
 return 200 + (concentration - 150.4) / (250.4 - 150.4) * 100
 else:
 return 300 + (concentration - 250.4) / (350.4 - 250.4) * 100
 
 def _calculate_pm10_aqi(self, concentration):
 """Calculate PM10 AQI"""
 if concentration <= 54:
 return (concentration / 54) * 50
 elif concentration <= 154:
 return 50 + (concentration - 54) / (154 - 54) * 50
 elif concentration <= 254:
 return 100 + (concentration - 154) / (254 - 154) * 50
 elif concentration <= 354:
 return 150 + (concentration - 154) / (354 - 154) * 50
 elif concentration <= 424:
 return 200 + (concentration - 354) / (424 - 354) * 100
 else:
 return 300 + (concentration - 424) / (604 - 424) * 100
 
 def _calculate_no2_aqi(self, concentration):
 """Calculate NO2 AQI"""
 if concentration <= 53:
 return (concentration / 53) * 50
 elif concentration <= 100:
 return 50 + (concentration - 53) / (100 - 53) * 50
 elif concentration <= 360:
 return 100 + (concentration - 100) / (360 - 100) * 50
 elif concentration <= 649:
 return 150 + (concentration - 360) / (649 - 360) * 50
 elif concentration <= 1249:
 return 200 + (concentration - 649) / (1249 - 649) * 100
 else:
 return 300 + (concentration - 1249) / (2049 - 1249) * 100
 
 def _calculate_so2_aqi(self, concentration):
 """Calculate SO2 AQI"""
 if concentration <= 35:
 return (concentration / 35) * 50
 elif concentration <= 75:
 return 50 + (concentration - 35) / (75 - 35) * 50
 elif concentration <= 185:
 return 100 + (concentration - 35) / (185 - 35) * 50
 elif concentration <= 304:
 return 150 + (concentration - 185) / (304 - 185) * 50
 elif concentration <= 604:
 return 200 + (concentration - 304) / (604 - 304) * 100
 else:
 return 300 + (concentration - 604) / (1004 - 604) * 100
 
 def _calculate_co_aqi(self, concentration):
 """Calculate CO AQI"""
 if concentration <= 4.4:
 return (concentration / 4.4) * 50
 elif concentration <= 9.4:
 return 50 + (concentration - 4.4) / (9.4 - 4.4) * 50
 elif concentration <= 12.4:
 return 100 + (concentration - 9.4) / (12.4 - 9.4) * 50
 elif concentration <= 15.4:
 return 150 + (concentration - 12.4) / (15.4 - 12.4) * 50
 elif concentration <= 30.4:
 return 200 + (concentration - 15.4) / (30.4 - 15.4) * 100
 else:
 return 300 + (concentration - 30.4) / (50.4 - 30.4) * 100
 
 def _calculate_o3_aqi(self, concentration):
 """Calculate O3 AQI"""
 if concentration <= 54:
 return (concentration / 54) * 50
 elif concentration <= 70:
 return 50 + (concentration - 54) / (70 - 54) * 50
 elif concentration <= 85:
 return 100 + (concentration - 70) / (85 - 70) * 50
 elif concentration <= 105:
 return 150 + (concentration - 85) / (105 - 85) * 50
 elif concentration <= 200:
 return 200 + (concentration - 105) / (200 - 105) * 100
 else:
 return 300 + (concentration - 200) / (400 - 200) * 100
 
 def prepare_data(self, data, target='aqi'):
 """Prepare data for modeling with time features"""
 df = data.copy()
 
 # Extract time features
 if 'timestamp' in df.columns:
 df['timestamp'] = pd.to_datetime(df['timestamp'])
 df['hour'] = df['timestamp'].dt.hour
 df['day'] = df['timestamp'].dt.day
 df['weekday'] = df['timestamp'].dt.weekday
 df['week'] = df['timestamp'].dt.isocalendar().week
 df['month'] = df['timestamp'].dt.month
 df['year'] = df['timestamp'].dt.year
 
 # Time encoding
 df['hour_sin'] = np.sin(2 * np.pi * df['hour'] / 24)
 df['hour_cos'] = np.cos(2 * np.pi * df['hour'] / 24)
 
 # Weekday encoding
 df['weekday_sin'] = np.sin(2 * np.pi * df['weekday'] / 7)
 df['weekday_cos'] = np.cos(2 * np.pi * df['weekday'] / 7)
 
 # Month encoding
 df['month_sin'] = np.sin(2 * np.pi * df['month'] / 12)
 df['month_cos'] = np.cos(2 * np.pi * df['month'] / 12)
 
 # Previous data points
 for lag in [1, 2, 3, 4, 5, 6, 12, 24]:
 if target in df.columns:
 df[f'{target}_lag_{lag}'] = df[target].shift(lag)
 
 # Moving averages
 for window in [3, 6, 12, 24]:
 if target in df.columns:
 df[f'{target}_rolling_mean_{window}'] = df[target].rolling(window=window).mean()
 df[f'{target}_rolling_std_{window}'] = df[target].rolling(window=window).std()
 
 # Drop rows with missing values
 df = df.dropna()
 
 return df
 
 def train_model(self, model_type='random_forest', features=None, target='aqi'):
 """Train air quality prediction model"""
 if features is None:
 features = ['temperature', 'humidity', 'wind_speed', 'traffic_flow', 
 'hour_sin', 'hour_cos', 'weekday_sin', 'weekday_cos',
 f'{target}_lag_1', f'{target}_lag_24', 
 f'{target}_rolling_mean_24']
 
 # Prepare data
 processed_data = self.prepare_data(self.data, target)
 
 # Split data
 train_size = int(len(processed_data) * 0.8)
 train_data = processed_data.iloc[:train_size]
 test_data = processed_data.iloc[train_size:]
 
 X_train = train_data[features]
 y_train = train_data[target]
 X_test = test_data[features]
 y_test = test_data[target]
 
 # Scale features
 scaler = StandardScaler()
 X_train_scaled = scaler.fit_transform(X_train)
 X_test_scaled = scaler.transform(X_test)
 
 # Train model
 if model_type == 'random_forest':
 model = RandomForestRegressor(
 n_estimators=100,
 max_depth=10,
 random_state=42
 )
 elif model_type == 'gradient_boosting':
 model = GradientBoostingRegressor(
 n_estimators=100,
 max_depth=4,
 learning_rate=0.1,
 random_state=42
 )
 elif model_type == 'linear':
 from sklearn.linear_model import LinearRegression
 model = LinearRegression()
 elif model_type == 'ridge':
 from sklearn.linear_model import Ridge
 model = Ridge(alpha=1.0)
 else:
 model = RandomForestRegressor(random_state=42)
 
 model.fit(X_train_scaled, y_train)
 
 # Make predictions
 y_pred = model.predict(X_test_scaled)
 
 # Calculate metrics
 metrics = {
 'mae': mean_absolute_error(y_test, y_pred),
 'rmse': np.sqrt(mean_squared_error(y_test, y_pred)),
 'r2': r2_score(y_test, y_pred),
 'mape': np.mean(np.abs((y_test - y_pred) / np.maximum(y_test, 1))) * 100
 }
 
 # Save model and scaler
 self.models[model_type] = model
 self.scalers[model_type] = scaler
 self.features = features
 
 return metrics, X_test, y_test, y_pred
 
 def predict_future(self, model_type='random_forest', steps_ahead=24):
 """Predict future air quality"""
 if model_type not in self.models:
 return None
 
 model = self.models[model_type]
 scaler = self.scalers[model_type]
 
 # Get the last data point
 processed_data = self.prepare_data(self.data)
 last_data = processed_data.iloc[-1:][self.features]
 
 predictions = []
 
 # For tree-based models, we need to simulate future
 current_features = last_data.copy()
 
 for i in range(steps_ahead):
 # Scale features
 features_scaled = scaler.transform(current_features)
 
 # Predict
 pred = model.predict(features_scaled)[0]
 predictions.append(pred)
 
 # Update features for next step
 if i < steps_ahead - 1:
 # Shift previous data
 current_features[f'aqi_lag_1'] = pred
 
 # Update moving averages
 if 'aqi_rolling_mean_24' in current_features.columns:
 current_features[f'aqi_rolling_mean_24'] = pred
 
 return predictions
 
 def simulate_scenario(self, scenario_type, impact_level):
 """Simulate what-if scenarios"""
 base_data = self.data.copy()
 
 if scenario_type == 'traffic_increase':
 # Increase traffic flow
 multiplier = 1 + (impact_level / 100)
 base_data['traffic_flow'] = base_data['traffic_flow'] * multiplier
 
 # Estimate impact on air quality (simplified)
 base_data['pm2_5'] = base_data['pm2_5'] * (1 + 0.2 * multiplier)
 base_data['no2'] = base_data['no2'] * (1 + 0.3 * multiplier)
 
 elif scenario_type == 'industrial_output':
 # Change industrial output
 change = impact_level / 100
 base_data['industrial_output'] = base_data['industrial_output'] * (1 + change)
 
 # Estimate impact
 base_data['so2'] = base_data['so2'] * (1 + 0.4 * change)
 base_data['pm10'] = base_data['pm10'] * (1 + 0.3 * change)
 
 elif scenario_type == 'weather_change':
 # Weather changes
 base_data['wind_speed'] = base_data['wind_speed'] * (1 + impact_level / 100)
 
 # Higher wind disperses pollutants
 for pollutant in ['pm2_5', 'pm10', 'no2', 'so2']:
 if pollutant in base_data.columns:
 base_data[pollutant] = base_data[pollutant] / (1 + abs(impact_level) / 200)
 
 elif scenario_type == 'green_zone':
 # Create green zone (reduce pollution)
 reduction = impact_level / 100
 for pollutant in ['pm2_5', 'pm10', 'no2', 'so2', 'co']:
 if pollutant in base_data.columns:
 base_data[pollutant] = base_data[pollutant] * (1 - reduction)
 
 # Recalculate AQI
 base_data['aqi'] = self.calculate_aqi(base_data)
 
 return base_data
 
